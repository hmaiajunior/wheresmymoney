generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  password        String
  name            String
  cycleStartDay   Int              @default(1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  transactions    Transaction[]
  categories      Category[]
  accountBalances AccountBalance[]
}

model Category {
  id           String        @id @default(cuid())
  name         String        @unique
  color        String?
  isSystem     Boolean       @default(false)
  userId       String?
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model PaymentMethod {
  id           String        @id @default(cuid())
  name         String        @unique
  type         String
  transactions Transaction[]
}

model Transaction {
  id              String          @id @default(cuid())
  date            DateTime
  type            TransactionType
  categoryId      String?
  category        Category?       @relation(fields: [categoryId], references: [id])
  source          String?
  description     String
  amount          Decimal         @db.Decimal(10, 2)
  paymentMethodId String?
  paymentMethod   PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  expenseType     ExpenseType?
  isInstallment   Boolean         @default(false)
  installmentInfo String?
  cycleDate       DateTime?       // período de referência (importado da coluna Ciclo da planilha)
  isConfirmed     Boolean         @default(true)  // false = réplica pendente de validação
  isOneOff        Boolean         @default(false) // true = evento único; não entra no forecast nem no histórico de esporádicas
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, categoryId])
}

enum TransactionType {
  RECEITA
  DESPESA
}

enum ExpenseType {
  FIXO
  ESPORADICO
  TERCEIROS
}

model AccountBalance {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 1º dia do mês (UTC) — fechamento do ciclo correspondente
  referenceDate DateTime      @db.Date
  // saldo em conta NO FIM desse ciclo (após pagar todas as contas do mês)
  amount        Decimal       @db.Decimal(12, 2)
  source        BalanceSource
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([userId, referenceDate])
  @@index([userId, referenceDate])
}

enum BalanceSource {
  INITIAL        // saldo inicial cadastrado pelo usuário (1 só, o mais antigo)
  CALCULATED     // derivado: saldo do mês anterior + receitas - despesas (sem terceiros)
  MANUAL_ADJUST  // usuário corrigiu para bater com o extrato bancário
}
